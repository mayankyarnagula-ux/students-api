
const express = require("express");
const router = express.Router();

const {Addstudent} = require("../controllers/usercontrollers");
const {Delete} = require("../controllers/usercontrollers");
const {Update}=require("../controllers/usercontrollers")
const {Read}=require("../controllers/usercontrollers")
const {Sread}=require("../controllers/usercontrollers")


router.post("/students/add",Addstudent);
router.delete("/students/:id",Delete);
router.put("/students/update/:id",Update);
router.get("/students/:id",Read);
router.get("/students",Sread);
module.exports = router;